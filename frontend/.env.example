# ====================================================
# Crypto-Wallet Frontend — Variables de entorno
# ====================================================

# URL base del backend API (sin barra final)
# Desarrollo local:
REACT_APP_API_BASE_URL=http://localhost:4000/secure/api

# Producción / Codespaces — reemplaza con tu URL real:
# REACT_APP_API_BASE_URL=https://<tu-host>/secure/api

# Suprime los warnings de source-map de librerías de terceros (html5-qrcode, etc.)
GENERATE_SOURCEMAP=false
